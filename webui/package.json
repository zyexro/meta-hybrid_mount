    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@material/web": "^2.4.1",
    "kernelsu": "^3.0.2",
    "solid-js": "^1.9.13",
    "zod": "^4.4.3"
